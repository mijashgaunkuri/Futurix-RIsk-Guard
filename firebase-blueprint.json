{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's profile and account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's unique ID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's photo URL" },
        "startingBalance": { "type": "number", "description": "User's starting balance for the month" },
        "currentBalance": { "type": "number", "description": "User's current balance" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation date" },
        "role": { "type": "string", "enum": ["user"], "description": "User's role" },
        "lastResetMonth": { "type": "string", "description": "Last month the balance was reset (e.g., '2026-3')" }
      },
      "required": ["uid", "email", "displayName", "startingBalance", "currentBalance", "createdAt", "role", "lastResetMonth"]
    },
    "Trade": {
      "title": "Trade Entry",
      "description": "A single trade entry in the journal",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Trade unique ID" },
        "symbol": { "type": "string", "description": "Trading symbol" },
        "entryPrice": { "type": "number", "description": "Entry price" },
        "stopLoss": { "type": "number", "description": "Stop loss price" },
        "quantity": { "type": "number", "description": "Trade quantity" },
        "direction": { "type": "string", "enum": ["LONG", "SHORT"], "description": "Trade direction" },
        "status": { "type": "string", "enum": ["OPEN", "CLOSED"], "description": "Trade status" },
        "date": { "type": "string", "format": "date-time", "description": "Trade date" },
        "exitPrice": { "type": "number", "description": "Exit price" },
        "fees": { "type": "number", "description": "Trading fees" },
        "pnl": { "type": "number", "description": "Profit and loss" },
        "netPnl": { "type": "number", "description": "Net profit and loss" },
        "notes": { "type": "string", "description": "Trade notes" },
        "strategy": { "type": "string", "description": "Trading strategy used" },
        "timeframe": { "type": "string", "description": "Trading timeframe" },
        "emotion": { "type": "string", "description": "User emotion during trade" },
        "marketCondition": { "type": "string", "description": "Market condition during trade" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Trade tags" }
      },
      "required": ["id", "symbol", "entryPrice", "stopLoss", "quantity", "direction", "status", "date"]
    },
    "BalanceHistory": {
      "title": "Balance History Entry",
      "description": "An entry in the user's balance history",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "History entry unique ID" },
        "date": { "type": "string", "format": "date-time", "description": "Entry date" },
        "amount": { "type": "number", "description": "Amount changed" },
        "type": { "type": "string", "enum": ["DEPOSIT", "WITHDRAWAL", "TRADE", "RESET"], "description": "Type of balance change" },
        "note": { "type": "string", "description": "Optional note" },
        "balanceAfter": { "type": "number", "description": "Balance after the change" }
      },
      "required": ["id", "date", "amount", "type", "balanceAfter"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/trades": {
      "schema": "Trade",
      "description": "User's trade entries"
    },
    "/users/{userId}/balanceHistory": {
      "schema": "BalanceHistory",
      "description": "User's balance history entries"
    }
  }
}
