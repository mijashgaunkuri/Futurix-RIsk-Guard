rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - email: string (required) - User's email
    //   - displayName: string (required) - User's display name
    //   - photoURL: string (optional) - User's photo URL
    //   - startingBalance: number (required) - User's starting balance for the month
    //   - currentBalance: number (required) - User's current balance
    //   - createdAt: timestamp (required) - Account creation date
    //   - role: string (required) - User's role (e.g., 'user')
    //   - lastResetMonth: string (required) - Last month the balance was reset (e.g., '2026-3')
    //
    // Sub-collection: users/{userId}/trades
    // Document ID: {tradeId}
    // Fields:
    //   - id: string (required)
    //   - symbol: string (required)
    //   - entryPrice: number (required)
    //   - stopLoss: number (required)
    //   - quantity: number (required)
    //   - direction: string (required)
    //   - status: string (required)
    //   - date: string (required)
    //   [... other trade fields]
    //
    // Sub-collection: users/{userId}/balanceHistory
    // Document ID: {historyId}
    // Fields:
    //   - id: string (required)
    //   - date: string (required)
    //   - amount: number (required)
    //   - type: string (required)
    //   - balanceAfter: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              (request.auth.token.email == "mijashchhetri1011@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'startingBalance', 'currentBalance', 'createdAt', 'role', 'lastResetMonth']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.startingBalance is number &&
             data.currentBalance is number &&
             data.role in ['user', 'admin'] &&
             (!('dailyGoals' in data) || data.dailyGoals is map);
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['id', 'symbol', 'entryPrice', 'stopLoss', 'quantity', 'direction', 'status', 'date']) &&
             data.id is string &&
             data.symbol is string &&
             data.entryPrice is number &&
             data.stopLoss is number &&
             data.quantity is number &&
             data.direction in ['LONG', 'SHORT'] &&
             data.status in ['OPEN', 'CLOSED'] &&
             data.date is string;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['id', 'date', 'amount', 'type', 'balanceAfter']) &&
             data.id is string &&
             data.date is string &&
             data.amount is number &&
             data.type in ['DEPOSIT', 'WITHDRAWAL', 'TRADE', 'RESET', 'SET'] &&
             data.balanceAfter is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      
      match /trades/{tradeId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTrade(request.resource.data);
        allow update: if isOwner(userId) && isValidTrade(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /balanceHistory/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidHistory(request.resource.data);
        allow update: if isOwner(userId) && isValidHistory(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
